---
const {
  title = "Serverless Changelog",
  description = "Investor-facing changelog web app",
  admin = false
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #09090b;
        --bg-soft: #101014;
        --bg-panel: rgba(19, 20, 26, 0.92);
        --bg-panel-strong: #171821;
        --line: rgba(255, 255, 255, 0.08);
        --line-strong: rgba(255, 255, 255, 0.14);
        --text: #f5f7fb;
        --muted: #afb4c4;
        --muted-strong: #d8dbea;
        --accent: #ff9f43;
        --accent-soft: rgba(255, 159, 67, 0.14);
        --accent-2: #7dd3fc;
        --danger: #f87171;
        --success: #4ade80;
        --shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
        --radius: 22px;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        font-family: "Manrope", "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(125, 211, 252, 0.12), transparent 28%),
          radial-gradient(circle at top right, rgba(255, 159, 67, 0.16), transparent 24%),
          linear-gradient(180deg, #0d0d11 0%, #09090b 100%);
        color: var(--text);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        border-radius: 18px;
      }

      button,
      input,
      textarea,
      select {
        font: inherit;
      }

      .page-shell {
        width: min(1180px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 22px 0 80px;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding: 10px 0 22px;
      }

      .brand {
        display: flex;
        align-items: baseline;
        gap: 14px;
      }

      .brand-mark {
        font-size: 1.25rem;
        font-weight: 800;
        letter-spacing: -0.04em;
      }

      .brand-copy {
        color: var(--muted);
        font-size: 0.92rem;
      }

      .header-actions {
        display: flex;
        gap: 10px;
      }

      .ghost-link,
      .primary-button,
      .secondary-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border-radius: 999px;
        border: 1px solid var(--line-strong);
        padding: 12px 18px;
        transition: 180ms ease;
        cursor: pointer;
      }

      .ghost-link,
      .secondary-button {
        background: rgba(255, 255, 255, 0.02);
      }

      .primary-button {
        background: linear-gradient(135deg, var(--accent), #ffbf69);
        color: #121212;
        border-color: transparent;
        font-weight: 800;
      }

      .ghost-link:hover,
      .primary-button:hover,
      .secondary-button:hover {
        transform: translateY(-1px);
      }

      .main-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.65fr) minmax(280px, 360px);
        gap: 28px;
      }

      .feed-column {
        min-width: 0;
      }

      .sticky-column {
        position: sticky;
        top: 18px;
        align-self: start;
      }

      .hero-panel,
      .card,
      .side-card,
      .admin-card {
        background: var(--bg-panel);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
      }

      .hero-panel {
        padding: 24px;
        margin-bottom: 20px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.04);
        color: var(--muted-strong);
        font-size: 0.78rem;
        letter-spacing: 0.02em;
        text-transform: uppercase;
      }

      .hero-title {
        margin: 16px 0 10px;
        font-size: clamp(2rem, 4vw, 3.5rem);
        line-height: 0.96;
        letter-spacing: -0.06em;
      }

      .hero-copy {
        margin: 0;
        max-width: 760px;
        color: var(--muted);
        font-size: 1.03rem;
        line-height: 1.7;
      }

      .search-row {
        display: flex;
        gap: 12px;
        margin-top: 22px;
      }

      .search-input,
      .field,
      .field-textarea,
      .field-select {
        width: 100%;
        border-radius: 16px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.03);
        color: var(--text);
        padding: 14px 16px;
        outline: none;
        transition: border-color 160ms ease, background 160ms ease;
      }

      .search-input:focus,
      .field:focus,
      .field-textarea:focus,
      .field-select:focus {
        border-color: rgba(255, 159, 67, 0.45);
        background: rgba(255, 255, 255, 0.05);
      }

      .field-textarea {
        min-height: 150px;
        resize: vertical;
      }

      .stack {
        display: grid;
        gap: 16px;
      }

      .feed {
        display: grid;
        gap: 18px;
      }

      .post-entry {
        display: grid;
        grid-template-columns: 148px minmax(0, 1fr);
        gap: 18px;
        align-items: start;
      }

      .post-entry-detail {
        grid-template-columns: 170px minmax(0, 1fr);
      }

      .post-rail {
        display: grid;
        gap: 12px;
        justify-items: start;
        padding-top: 16px;
      }

      .post-card {
        padding: 24px 24px 22px;
      }

      .post-date {
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.5;
      }

      .tag-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .tag-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 11px;
        border-radius: 999px;
        border: 1px solid color-mix(in srgb, var(--tag-color, var(--accent)) 36%, rgba(255, 255, 255, 0.15));
        background: color-mix(in srgb, var(--tag-color, var(--accent)) 18%, rgba(255, 255, 255, 0.02));
        color: var(--muted-strong);
        font-size: 0.78rem;
        line-height: 1;
      }

      .tag-pill::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--tag-color, var(--accent));
        box-shadow: 0 0 0 4px color-mix(in srgb, var(--tag-color, var(--accent)) 18%, transparent);
      }

      .post-title {
        margin: 0;
        font-size: clamp(1.5rem, 2vw, 2.2rem);
        letter-spacing: -0.05em;
      }

      .post-subtitle {
        margin: 8px 0 0;
        color: var(--muted-strong);
        font-size: 1rem;
        line-height: 1.55;
      }

      .post-body {
        margin-top: 18px;
        color: #d7dbee;
        font-size: 0.98rem;
        line-height: 1.82;
      }

      .post-body h1,
      .post-body h2,
      .post-body h3,
      .post-body h4 {
        letter-spacing: -0.04em;
        line-height: 1.1;
        margin: 1.2em 0 0.55em;
      }

      .post-body h1 {
        font-size: 1.8rem;
      }

      .post-body h2 {
        font-size: 1.35rem;
      }

      .post-body h3 {
        font-size: 1.12rem;
      }

      .post-body h4 {
        font-size: 1rem;
      }

      .post-body p,
      .post-body ul,
      .post-body ol,
      .post-body blockquote {
        margin: 0 0 1em;
      }

      .post-body p,
      .post-body li {
        font-size: 0.98rem;
      }

      .post-body ul,
      .post-body ol {
        padding-left: 1.2rem;
      }

      .post-body li + li {
        margin-top: 0.38rem;
      }

      .post-body img {
        display: block;
        margin: 1.15rem 0;
      }

      .post-body pre,
      .post-body code {
        font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
      }

      .post-body pre {
        overflow: auto;
        padding: 16px;
        border-radius: 16px;
        background: rgba(0, 0, 0, 0.28);
      }

      .post-body blockquote {
        padding-left: 18px;
        border-left: 3px solid rgba(125, 211, 252, 0.45);
        color: #d2e8f3;
      }

      .locked-panel,
      .message-box {
        margin-top: 20px;
        padding: 18px;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.03);
      }

      .locked-title {
        margin: 0 0 8px;
        font-size: 1rem;
      }

      .muted {
        color: var(--muted);
      }

      .inline-form {
        display: flex;
        gap: 10px;
        margin-top: 14px;
      }

      .inline-form .field {
        flex: 1;
      }

      .inline-feedback {
        margin-top: 10px;
        color: var(--muted);
        font-size: 0.92rem;
      }

      .side-card,
      .admin-card {
        padding: 22px;
      }

      .side-title,
      .section-title,
      .admin-title {
        margin: 0 0 8px;
        font-size: 1.2rem;
        letter-spacing: -0.04em;
      }

      .side-copy,
      .section-copy {
        margin: 0 0 16px;
        color: var(--muted);
        line-height: 1.65;
      }

      .field-label {
        display: block;
        margin: 0 0 8px;
        color: var(--muted-strong);
        font-size: 0.93rem;
      }

      .field-row {
        display: grid;
        gap: 14px;
      }

      .color-field {
        min-height: 52px;
        padding: 8px;
      }

      .checkbox-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 10px;
      }

      .checkbox-pill {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 14px;
        border: 1px solid var(--line);
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.02);
      }

      .checkbox-pill input {
        margin: 0;
      }

      .checkbox-pill .tag-pill {
        pointer-events: none;
      }

      .load-more-row {
        display: flex;
        justify-content: center;
        padding-top: 8px;
      }

      .load-more-row[hidden] {
        display: none;
      }

      .empty-state {
        padding: 28px;
        text-align: center;
        color: var(--muted);
      }

      .admin-shell {
        display: grid;
        gap: 18px;
      }

      .access-gate-shell {
        display: grid;
        place-items: center;
        min-height: calc(100vh - 180px);
      }

      .access-gate-card {
        width: min(520px, 100%);
      }

      .access-gate-title {
        font-size: clamp(2rem, 4vw, 2.8rem);
        margin-bottom: 12px;
      }

      .admin-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(300px, 0.9fr);
        gap: 18px;
      }

      .panel-grid {
        display: grid;
        gap: 18px;
      }

      .tag-manager-list {
        display: grid;
        gap: 12px;
        margin-top: 18px;
      }

      .tag-edit-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 84px auto auto;
        gap: 10px;
        align-items: center;
      }

      .message-bar {
        padding: 14px 16px;
        border-radius: 16px;
        margin-bottom: 14px;
      }

      .message-bar.error {
        background: rgba(248, 113, 113, 0.12);
        border: 1px solid rgba(248, 113, 113, 0.22);
        color: #ffc7c7;
      }

      .message-bar.success {
        background: rgba(74, 222, 128, 0.12);
        border: 1px solid rgba(74, 222, 128, 0.22);
        color: #c9ffd9;
      }

      .post-table {
        width: 100%;
        border-collapse: collapse;
      }

      .post-table th,
      .post-table td {
        padding: 14px 0;
        border-bottom: 1px solid var(--line);
        text-align: left;
        vertical-align: top;
      }

      .post-table th {
        color: var(--muted);
        font-size: 0.84rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .table-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .micro-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        border: 1px solid var(--line-strong);
        background: transparent;
        color: var(--text);
        padding: 8px 12px;
        cursor: pointer;
      }

      .micro-button.danger {
        border-color: rgba(248, 113, 113, 0.28);
        color: #ffc9c9;
      }

      .editor-note {
        margin-top: 8px;
        color: var(--muted);
        font-size: 0.88rem;
      }

      .rail-back-link {
        padding-inline: 14px;
      }

      .EasyMDEContainer {
        width: 100%;
      }

      .EasyMDEContainer .CodeMirror,
      .EasyMDEContainer .editor-preview,
      .EasyMDEContainer .editor-preview-side {
        background: rgba(255, 255, 255, 0.03);
        color: var(--text);
        border-color: var(--line);
        min-height: 280px;
      }

      .EasyMDEContainer .editor-toolbar {
        border: 1px solid var(--line);
        border-bottom: none;
        border-radius: 16px 16px 0 0;
        background: rgba(255, 255, 255, 0.04);
      }

      .EasyMDEContainer .CodeMirror {
        border: 1px solid var(--line);
        border-radius: 0 0 16px 16px;
        padding: 8px 0;
      }

      .EasyMDEContainer .editor-toolbar button,
      .EasyMDEContainer .editor-toolbar i.separator {
        color: var(--muted-strong);
      }

      .admin-page .page-shell {
        width: min(1240px, calc(100vw - 32px));
      }

      @media (max-width: 980px) {
        .main-grid,
        .admin-grid {
          grid-template-columns: 1fr;
        }

        .sticky-column {
          position: static;
        }
      }

      @media (max-width: 720px) {
        .page-shell {
          width: min(100vw - 22px, 100%);
          padding-top: 16px;
        }

        .post-entry,
        .post-entry-detail,
        .tag-edit-row {
          grid-template-columns: 1fr;
        }

        .post-rail {
          padding-top: 0;
        }

        .site-header,
        .brand,
        .search-row,
        .inline-form {
          flex-direction: column;
          align-items: stretch;
        }

        .hero-panel,
        .post-card,
        .side-card,
        .admin-card {
          padding: 18px;
        }
      }
    </style>
  </head>
  <body class:list={[admin && "admin-page"]}>
    <div class="page-shell">
      <slot />
    </div>
  </body>
</html>
